# Anthropic
ANTHROPIC_API_KEY=your_key_here

# Failure injection (none | row_drop | schema_drift | null_spike | latency)
INJECT_FAILURE=none

# Tool server
TOOL_SERVER_HOST=localhost
TOOL_SERVER_PORT=8000

# Agent server
AGENT_SERVER_HOST=localhost
AGENT_SERVER_PORT=8001

# Database (mock target)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pipeline_qa
POSTGRES_USER=qa_user
POSTGRES_PASSWORD=qa_pass

# Kafka (mock)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=pipeline-events

# n8n
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=password
N8N_PORT=5678

# Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
JENKINS_WEBHOOK_URL=http://jenkins:8080/generic-webhook-trigger/invoke
JENKINS_TOKEN=your_token_here

# Thresholds (optional overrides)
ROW_DROP_THRESHOLD=5.0
NULL_RATE_THRESHOLD=0.05
KAFKA_LAG_THRESHOLD=10000
